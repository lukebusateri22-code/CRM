{
  "name": "startup-crm",
  "version": "1.0.0",
  "description": "Modern CRM for startups",
  "main": "server/enhancedServer.js",
  "scripts": {
    "start": "node server/productionServer.js",
    "server": "node server/productionServer.js",
    "dev-old": "node server/enhancedServer.js",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "pg": "^8.11.3",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "csv-parse": "^5.5.3",
    "multer": "^1.4.5-lts.1",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
