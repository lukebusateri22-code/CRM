{
  "name": "startup-crm",
  "version": "1.0.0",
  "description": "Modern CRM for startups",
  "main": "server/enhancedServer.js",
  "scripts": {
    "start": "node server/enhancedServer.js",
    "server": "node server/enhancedServer.js",
    "client": "cd client && npm start",
